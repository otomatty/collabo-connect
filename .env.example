# API base URL (no trailing slash). Auth is cookie-based via Better Auth.
# ローカル: 未設定または http://localhost:8787（ローカルの `wrangler dev` で api を起動する場合）
# 本番・プロトタイプ: Cloudflare Workers の API URL
#   （ローカルから本番 API に繋ぐ場合は api/wrangler.toml の BETTER_AUTH_TRUSTED_ORIGINS / CORS_ORIGINS に localhost を含める）
VITE_API_URL=https://collabo-connect-api.workers.dev
