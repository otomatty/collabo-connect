# Railway injects DATABASE_URL via ${{Postgres.DATABASE_URL}}
DATABASE_URL=postgresql://user:pass@host:5432/dbname
PORT=3000

# Supabase JWT verification (Project Settings → API → JWT Secret)
SUPABASE_JWT_SECRET=your-jwt-secret

# Gemini API (for ai-interview and generate-daily-question)
GEMINI_API_KEY=your-gemini-api-key

# Cron calls POST /api/cron/generate-daily-question with this header
CRON_SECRET=your-cron-secret
