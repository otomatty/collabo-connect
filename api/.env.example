# Railway injects DATABASE_URL via ${{Postgres.DATABASE_URL}}
DATABASE_URL=postgresql://user:pass@host:5432/dbname
PORT=3000

# Better Auth (generate secret with: openssl rand -base64 32)
BETTER_AUTH_SECRET=your-better-auth-secret
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:8080
# CORS: フロントの origin をカンマ区切り（credentials 利用時は必須）
# 本番例: https://web-production-28ea3.up.railway.app
CORS_ORIGINS=http://localhost:8080,http://localhost:5173

# Gemini API (for ai-interview and generate-daily-question)
GEMINI_API_KEY=your-gemini-api-key

# Cron calls POST /api/cron/generate-daily-question with x-cron-secret header
CRON_SECRET=your-cron-secret

# Optional: magic link email (Resend)
# RESEND_API_KEY=re_xxxx
# RESEND_FROM=onboarding@resend.dev
